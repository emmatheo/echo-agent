# ------------------------------------------------------------------
# Echo Agent — environment variables
# Copy to `.env.local` (Next.js loads it automatically) and fill in.
# ------------------------------------------------------------------

# --- LLM (required) -----------------------------------------------
# Any OpenAI-compatible API. Default endpoint is Google Gemini's free
# tier — get a free key (no credit card) at https://aistudio.google.com
LLM_API_KEY=your-api-key-here
# GEMINI_API_KEY also works as an alias for LLM_API_KEY.
# Optional endpoint + model overrides (Gemini defaults shown).
# gemini-flash-latest always points at Google's newest Flash model.
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai
# FREE_MODEL=gemini-flash-latest
# PREMIUM_MODEL=gemini-flash-latest   # or gemini-pro-latest if you have quota
#
# Other free-tier providers (set all three):
#   Groq:       LLM_BASE_URL=https://api.groq.com/openai/v1
#               FREE_MODEL=llama-3.3-70b-versatile  PREMIUM_MODEL=llama-3.3-70b-versatile
#   OpenRouter: LLM_BASE_URL=https://openrouter.ai/api/v1
#               (pick models with the ":free" suffix)

# --- x402 / payments (required for premium tier) ------------------
# Wallet that RECEIVES the 0.02 USDC premium payments.
PAY_TO_ADDRESS=0xYourReceivingAddressHere
# INLINE facilitator: the server settles payments itself, signing with this
# wallet. Fund it with a little INJ (gas) on the configured network.
# TESTNET: use a fresh throwaway wallet + testnet INJ from the faucet.
X402_FACILITATOR_PRIVATE_KEY=0xFacilitatorWalletPrivateKey
# Alternative: a remote facilitator service (leave unset to settle inline).
# X402_FACILITATOR_URL=
# Demo "agent wallet" that PAYS premium requests from the browser.
# Fund it with testnet USDC (Circle faucet). Needs no gas. Because it is
# NEXT_PUBLIC_*, the key ships in the JS bundle — TESTNET ONLY, tiny amounts.
NEXT_PUBLIC_PAYER_PRIVATE_KEY=0xDemoPayerWalletPrivateKey

# --- Injective EVM chain (defaults = MAINNET) ---------------------
# Server-side chain config (the x402 middleware + payment quotes):
# INJ_CHAIN_NAME=Injective
# INJ_CHAIN_ID=1776
# INJ_RPC_URL=https://sentry.evm-rpc.injective.network/
# INJ_EXPLORER_URL=https://blockscout.injective.network
# INJ_BRIDGE_URL=https://bridge.injective.network
# USDC_ADDRESS=0xa00C59fF5a080D2b954d0c75e46E22a0c371235a
#
# Client-side chain config (the wallet connect/add-chain flow). These are
# inlined into the browser bundle at BUILD time, so set them in the deploy
# environment (e.g. Render) before building. Defaults = mainnet.
# NEXT_PUBLIC_INJ_CHAIN_ID=1776
# NEXT_PUBLIC_INJ_CHAIN_NAME=Injective
# NEXT_PUBLIC_INJ_RPC_URL=https://sentry.evm-rpc.injective.network/
# NEXT_PUBLIC_INJ_EXPLORER_URL=https://blockscout.injective.network
# NEXT_PUBLIC_USDC_ADDRESS=0xa00C59fF5a080D2b954d0c75e46E22a0c371235a
# NEXT_PUBLIC_INJ_BRIDGE_URL=https://bridge.injective.network
#
# --- TESTNET (chainId 1439) values ---------------------------------
# Set BOTH the server-side and NEXT_PUBLIC_ variables:
#   INJ_CHAIN_ID=1439                NEXT_PUBLIC_INJ_CHAIN_ID=1439
#   INJ_CHAIN_NAME="Injective Testnet"
#   INJ_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
#   NEXT_PUBLIC_INJ_RPC_URL=https://k8s.testnet.json-rpc.injective.network/
#   INJ_EXPLORER_URL=https://testnet.blockscout.injective.network
#   NEXT_PUBLIC_INJ_EXPLORER_URL=https://testnet.blockscout.injective.network
#   USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
#   NEXT_PUBLIC_USDC_ADDRESS=0x0C382e685bbeeFE5d3d9C29e29E341fEE8E84C5d
# Testnet USDC comes from Circle's faucet (https://faucet.circle.com).
# X402_FACILITATOR_URL must point at the TESTNET facilitator — get the
# current URL from https://docs.injective.network/developers-ai/x402
